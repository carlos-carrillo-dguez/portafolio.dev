---
// src/pages/gracias.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mensaje Enviado" description="Gracias por contactar con Carlos">
  <main class="flex flex-col items-center justify-center min-h-screen text-center px-4">
    <h1 class="text-4xl font-bold mb-4 text-[#4BB9C0]">¡Mensaje enviado!</h1>
    <p class="text-lg text-gray-300">Gracias por ponerte en contacto. Te responderé lo antes posible.</p>
    <a href="/" class="mt-8 bg-[#4BB9C0] text-slate-900 font-bold py-2 px-6 rounded-lg hover:bg-[#3d9ca2] transition font-mono">
      Volver al inicio
    </a>
  </main>
</Layout>